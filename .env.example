# Environment Configuration Template
# Copy this file to .env and fill in your actual values

# Application Environment
NODE_ENV=development

# Database Configuration
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority
DATABASE_URL=mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority

# Security Configuration
SESSION_SECRET=your-super-secure-random-string-at-least-32-characters-long

# Optional: Force HTTPS (for production)
FORCE_HTTPS=false

# Optional: Cookie Domain (for production)
COOKIE_DOMAIN=

# Optional: Frontend URL (for CORS)
FRONTEND_URL=

# Optional: Domain URL (for production)
DOMAIN_URL=

# Render-specific (auto-set by Render platform)
PORT=5000
RENDER_EXTERNAL_URL=
RENDER_SERVICE_NAME=
RENDER_REGION=

# Development Only
VITE_API_URL=http://localhost:5000